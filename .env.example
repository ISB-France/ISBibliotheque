# =============================================================================
# ISBibliotheque — Variables d'environnement
# =============================================================================
# Copier ce fichier vers .env et adapter les valeurs
#   cp .env.example .env
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 📱 Frontend (React / Vite)
# ─────────────────────────────────────────────────────────────────────────────

# URL de base du portail (utilisée pour les redirections auth et les liens)
# Ex: http://localhost:5173 (dev), https://portail.isb-group.fr (prod)
VITE_APP_URL=http://localhost:5173

# Titre du portail (affiché dans l'onglet et l'en-tête)
VITE_APP_TITLE=ISBibliotheque

# Identifiants Microsoft Entra ID (Azure AD)
# ── Client ID de l'application inscrite dans Azure AD
VITE_AZURE_CLIENT_ID=
# ── Tenant ID (répertoire) ISB Group
VITE_AZURE_TENANT_ID=
# ── Redirect URI après authentification
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# URL de l'API backend (si déployée séparément)
# Laisser vide si le backend n'est pas encore déployé
VITE_API_URL=http://localhost:3001/api

# Version de l'application (affichée dans le pied de page)
VITE_APP_VERSION=0.1.0

# Environnement cible
# Valeurs possibles : development, staging, production
VITE_APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 Backend (Node.js / Express)
# ─────────────────────────────────────────────────────────────────────────────

# Port d'écoute du serveur backend (config lit PORT)
BACKEND_PORT=4000

# Origines CORS autorisées (séparées par des virgules, * en dev)
CORS_ORIGIN=*

# Niveau de log
# Valeurs possibles : debug, info, warn, error
LOG_LEVEL=debug

# Authentification locale (v1 — remplaçable par Entra ID)
# ── Compte admin par défaut
AUTH_ADMIN_EMAIL=admin@isb-group.fr
AUTH_ADMIN_PASSWORD=admin
AUTH_ADMIN_NAME=Admin SI
# ── Clé secrète pour signer les JWT (générer une chaîne aléatoire en prod)
JWT_SECRET=change-me-to-a-random-string
# ── Durée de validité du token JWT
JWT_EXPIRES_IN=24h

# Authentification Microsoft Entra ID (futur — côté serveur)
# ── Client ID (identique au frontend)
AZURE_CLIENT_ID=
# ── Client Secret (généré depuis Azure AD > Certificates & secrets)
AZURE_CLIENT_SECRET=
# ── Tenant ID
AZURE_TENANT_ID=
# ── Scope de l'API Microsoft Graph
AZURE_SCOPES=https://graph.microsoft.com/.default

# Session
# ── Clé secrète pour signer les cookies de session (générer une chaîne aléatoire)
SESSION_SECRET=change-me-to-a-random-string

# Base de données (future)
# DATABASE_URL=postgresql://user:password@localhost:5432/isbibliotheque

# ─────────────────────────────────────────────────────────────────────────────
# 🐳 Docker & Déploiement
# ─────────────────────────────────────────────────────────────────────────────

# Tag de l'image Docker (utilisé par les scripts CI/CD)
DOCKER_IMAGE_TAG=isb-portail:latest

# Port d'exposition du container
DOCKER_PORT=80

# FQDN du serveur de production
# Ex: portail.isb-group.fr
PRODUCTION_HOST=

# Certificats SSL (chemin vers les fichiers)
# SSL_CERT_PATH=./certs/fullchain.pem
# SSL_KEY_PATH=./certs/privkey.pem

# ─────────────────────────────────────────────────────────────────────────────
# 📊 Monitoring & Observabilité (à venir)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry DSN (collecte d'erreurs)
# SENTRY_DSN=

# Logtail / BetterStack (log centralisé)
# LOGTAIL_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# ⚙️  Options avancées
# ─────────────────────────────────────────────────────────────────────────────

# Mode "dégradé" : désactiver l'auth pour les tests locaux
# ⚠️  Ne JAMAIS activer en production
DISABLE_AUTH=false

# Intervalle de vérification de santé backend (en ms)
HEALTH_CHECK_INTERVAL=30000
