[Unit]
Description=ISBibliotheque Recette
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/var/www/isbibliotheque-recette
ExecStart=/usr/bin/docker compose -f deploy/docker-compose.recette.yml --env-file /etc/isbibliotheque/recette.env -p isbibliotheque-recette up -d
ExecStop=/usr/bin/docker compose -f deploy/docker-compose.recette.yml -p isbibliotheque-recette down
StandardOutput=journal

[Install]
WantedBy=multi-user.target
